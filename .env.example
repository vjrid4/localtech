# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (socket auth, no password):
DATABASE_URL="postgresql://jana@localhost:5432/devicedna"
# VPS / production (with password):
# DATABASE_URL="postgresql://localtech:YOUR_DB_PASSWORD@localhost:5432/localtech_prod"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_48_for_production"
JWT_EXPIRES_IN="7d"

# ─── AI (optional) ────────────────────────────────────────────────────────────
# Enables real AI diagnosis in lib/ai/diagnosis.ts
ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://localtech.in"
NODE_ENV="development"

# ─── Optional integrations ────────────────────────────────────────────────────
# WhatsApp Business API (for customer status updates)
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_API_KEY=""

# Email (SMTP for estimate/invoice delivery)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""

# File uploads (receipts, device photos)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET="localtech-uploads"
# AWS_REGION="ap-south-1"
